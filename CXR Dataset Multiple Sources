    "# ---------------------------------------------------------------------\n",
    "# SOURCE 1: Saira Kiran / Ishrat Jabeen (Mendeley TB dataset)\n",
    "# Folder-based: Normal/ and Tuberculosis/\n",
    "# ---------------------------------------------------------------------\n",
    "SRC1_DIR =\"/kaggle/input/datasets/fadhillahrandyw/dataset-of-tuberculosis-chest-x-rays-images/Dataset of Tuberculosis Chest X-rays Images\"\n",
    "\n",
    "counter = 0\n",
    "normal_folder = os.path.join(SRC1_DIR,\"Normal Chest X-rays\")\n",
    "if os.path.isdir(normal_folder):\n",
    "    for fname in os.listdir(normal_folder):\n",
    "        if fname.lower().endswith((\".png\", \".jpg\", \".jpeg\")):\n",
    "            save_image(os.path.join(normal_folder, fname), \"Normal\", \"sairakiran\", counter)\n",
    "            counter += 1\n",
    "else:\n",
    "    print(f\"WARNING: Saira Kiran Normal folder not found: {normal_folder}\")\n",
    "\n",
    "counter = 0\n",
    "tb_folder = os.path.join(SRC1_DIR, \"TB Chest X-rays\")\n",
    "if os.path.isdir(tb_folder):\n",
    "    for fname in os.listdir(tb_folder):\n",
    "        if fname.lower().endswith((\".png\", \".jpg\", \".jpeg\")):\n",
    "            save_image(os.path.join(tb_folder, fname), \"TB\", \"sairakiran\", counter)\n",
    "            counter += 1\n",
    "else:\n",
    "    print(f\"WARNING: Saira Kiran TB folder not found: {tb_folder}\")\n",
    "\n",
    "# ---------------------------------------------------------------------\n",
    "# SOURCE 2: Belarus drug-resistant TB (DICOM, all TB-positive)\n",
    "# ---------------------------------------------------------------------\n",
    "SRC2_DIR = \"/kaggle/input/datasets/fadhillahrandyw/belarus-dataset\"\n",
    "IMAGE_SUBFOLDER2 = \"belarus\"  \n",
    " \n",
    "img_dir2 = os.path.join(SRC2_DIR, IMAGE_SUBFOLDER2)\n",
    "counter = 0\n",
    "if os.path.isdir(img_dir2):\n",
    "    for fname in os.listdir(img_dir2):\n",
    "        if fname.lower().endswith((\".png\", \".jpg\", \".jpeg\")):\n",
    "            save_image(os.path.join(img_dir2, fname), \"TB\", \"belarus\", counter, is_dicom=False)\n",
    "            counter += 1\n",
    "else:\n",
    "    print(f\"WARNING: Belarus image subfolder not found: {img_dir2} (check top-level printout above and adjust IMAGE_SUBFOLDER2)\")\n",
    "# ---------------------------------------------------------------------\n",
    "# SOURCE 3: NLM Montgomery + Shenzhen\n",
    "# (kmader/pulmonary-chest-xray-abnormalities)\n",
    "# Confirmed structure: filenames encode the label directly, e.g.\n",
    "# CHNCXR_0001_0.png / MCUCXR_0001_0.png -> last char before \".png\" is\n",
    "# 0 = normal, 1 = abnormal/TB.\n",
    "# ---------------------------------------------------------------------\n",
    "SRC3_DIR = \"/kaggle/input/datasets/kmader/pulmonary-chest-xray-abnormalities\"\n",
    "nlm_folders = [\n",
    "    os.path.join(SRC3_DIR, \"ChinaSet_AllFiles\", \"ChinaSet_AllFiles\", \"CXR_png\"),  # Shenzhen\n",
    "    os.path.join(SRC3_DIR, \"Montgomery\", \"MontgomerySet\", \"CXR_png\"),             # Montgomery\n",
    "]\n",
    "\n",
    "counter_normal3, counter_tb3 = 0, 0\n",
    "for folder in nlm_folders:\n",
    "    if not os.path.isdir(folder):\n",
    "        print(f\"WARNING: NLM folder not found: {folder}\")\n",
    "        continue\n",
    "    for fname in os.listdir(folder):\n",
    "        if not fname.lower().endswith(\".png\"):\n",
    "            continue\n",
    "        label_char = fname[-5]  # the \"X\" in ..._X.png\n",
    "        if label_char == \"0\":\n",
    "            save_image(os.path.join(folder, fname), \"Normal\", \"nlm\", counter_normal3)\n",
    "            counter_normal3 += 1\n",
    "        elif label_char == \"1\":\n",
    "            save_image(os.path.join(folder, fname), \"TB\", \"nlm\", counter_tb3)\n",
    "            counter_tb3 += 1\n",
    "\n",
    "# ---------------------------------------------------------------------\n",
    "# SOURCE 4: DA/DB Delhi dataset (vbookshelf/da-and-db-tb-chest-x-ray-datasets)\n",
    "# Folder layout not confirmed yet - inspect first, then fill in the loop\n",
    "# below. DA is jpg, DB is dicom (set is_dicom=True only for DB files).\n",
    "# ---------------------------------------------------------------------\n",
    "SRC4_DIR = \"/kaggle/input/datasets/vbookshelf/da-and-db-tb-chest-x-ray-datasets\"\n",
    "images_dir4 = os.path.join(SRC4_DIR, \"images\")\n",
    " \n",
    " \n",
    "def label_from_da_db_filename(fname):\n",
    "    \"\"\"Filenames look like da_test_nx9.jpg, db_train_p6.dcm,\n",
    "    db_test_nd548.dcm etc. The 3rd underscore-separated chunk starts\n",
    "    with 'n' (negative/Normal) or 'p' (positive/TB).\"\"\"\n",
    "    name_no_ext = os.path.splitext(fname)[0]\n",
    "    parts = name_no_ext.split(\"_\")\n",
    "    if len(parts) < 3:\n",
    "        return None\n",
    "    first_char = parts[2][0].lower()\n",
    "    if first_char == \"n\":\n",
    "        return \"Normal\"\n",
    "    elif first_char == \"p\":\n",
    "        return \"TB\"\n",
    "    return None\n",
    " \n",
    " \n",
    "counter_normal4, counter_tb4 = 0, 0\n",
    "for sub, is_dicom_flag in [(\"da\", False), (\"db\", True)]:\n",
    "    sub_dir = os.path.join(images_dir4, sub)\n",
    "    if not os.path.isdir(sub_dir):\n",
    "        print(f\"WARNING: folder not found: {sub_dir}\")\n",
    "        continue\n",
    "    for fname in os.listdir(sub_dir):\n",
    "        label = label_from_da_db_filename(fname)\n",
    "        if label is None:\n",
    "            print(f\"  Skipping unrecognized filename: {fname}\")\n",
    "            continue\n",
    "        src_path = os.path.join(sub_dir, fname)\n",
    "        if label == \"Normal\":\n",
    "            save_image(src_path, \"Normal\", \"dadb\", counter_normal4, is_dicom=is_dicom_flag)\n",
    "            counter_normal4 += 1\n",
    "        else:\n",
    "            save_image(src_path, \"TB\", \"dadb\", counter_tb4, is_dicom=is_dicom_flag)\n",
    "            counter_tb4 += 1\n"
   ]
