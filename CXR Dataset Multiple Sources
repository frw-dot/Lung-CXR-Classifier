    "\"\"\"\n",
    "Master merge: combine TB + Normal CXR images from multiple Kaggle datasets\n",
    "into ONE unified dataset (single folder structure + metadata CSV).\n",
    "\n",
    "WORKFLOW:\n",
    "1. Attach all source datasets to this notebook (Add Data button)\n",
    "2. Run this script\n",
    "3. Commit notebook (Save & Run All) -> Output tab -> \"New Dataset\"\n",
    "   to publish the result as a standalone, reusable Kaggle dataset\n",
    "\n",
    "Output structure:\n",
    "/kaggle/working/combined_cxr_dataset/\n",
    "    Normal/   <source>_00000.png, <source>_00001.png, ...\n",
    "    TB/       <source>_00000.png, ...\n",
    "    combined_metadata.csv   (filename, label, source)\n",
    "\"\"\"\n",
    "\n",
    "import os\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import pydicom\n",
    "from PIL import Image\n",
    "\n",
    "OUTPUT_DIR = \"/kaggle/working/combined_cxr_dataset\"\n",
    "NORMAL_DIR = os.path.join(OUTPUT_DIR, \"Normal\")\n",
    "TB_DIR = os.path.join(OUTPUT_DIR, \"TB\")\n",
    "RESIZE_TO = (256, 256)\n",
    "\n",
    "os.makedirs(NORMAL_DIR, exist_ok=True)\n",
    "os.makedirs(TB_DIR, exist_ok=True)\n",
    "\n",
    "records = []  # filename, label, source\n",
    "\n",
    "\n",
    "def save_image(src_path, label, source_name, counter, is_dicom=False):\n",
    "    \"\"\"Convert (if DICOM) / copy + resize an image, save with a unique\n",
    "    name, and log a metadata record.\"\"\"\n",
    "    dest_dir = TB_DIR if label == \"TB\" else NORMAL_DIR\n",
    "    new_name = f\"{source_name}_{counter:05d}.png\"\n",
    "    dest_path = os.path.join(dest_dir, new_name)\n",
    "\n",
    "    if is_dicom:\n",
    "        ds = pydicom.dcmread(src_path)\n",
    "        img = ds.pixel_array.astype(float)\n",
    "        slope = float(getattr(ds, \"RescaleSlope\", 1))\n",
    "        intercept = float(getattr(ds, \"RescaleIntercept\", 0))\n",
    "        img = img * slope + intercept\n",
    "        img_min, img_max = img.min(), img.max()\n",
    "        if img_max > img_min:\n",
    "            img = (img - img_min) / (img_max - img_min) * 255.0\n",
    "        img = img.astype(np.uint8)\n",
    "        if getattr(ds, \"PhotometricInterpretation\", \"MONOCHROME2\") == \"MONOCHROME1\":\n",
    "            img = 255 - img\n",
    "        pil_img = Image.fromarray(img)\n",
    "    else:\n",
    "        pil_img = Image.open(src_path).convert(\"L\")  # force grayscale\n",
    "\n",
    "    pil_img = pil_img.resize(RESIZE_TO)\n",
    "    pil_img.save(dest_path)\n",
    "    records.append({\"filename\": new_name, \"label\": label, \"source\": source_name})\n"
   ]
  },
