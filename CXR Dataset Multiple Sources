{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":16918587},{"sourceType":"datasetVersion","sourceId":5137726},{"sourceType":"datasetVersion","sourceId":16918386},{"sourceType":"datasetVersion","sourceId":20797}],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"\"\"\"\nMaster merge: combine TB + Normal CXR images from multiple Kaggle datasets\ninto ONE unified dataset (single folder structure + metadata CSV).\n\nWORKFLOW:\n1. Attach all source datasets to this notebook (Add Data button)\n2. Run this script\n3. Commit notebook (Save & Run All) -> Output tab -> \"New Dataset\"\n   to publish the result as a standalone, reusable Kaggle dataset\n\nOutput structure:\n/kaggle/working/combined_cxr_dataset/\n    Normal/   <source>_00000.png, <source>_00001.png, ...\n    TB/       <source>_00000.png, ...\n    combined_metadata.csv   (filename, label, source)\n\"\"\"\n\nimport os\nimport numpy as np\nimport pandas as pd\nimport pydicom\nfrom PIL import Image\n\nOUTPUT_DIR = \"/kaggle/working/combined_cxr_dataset\"\nNORMAL_DIR = os.path.join(OUTPUT_DIR, \"Normal\")\nTB_DIR = os.path.join(OUTPUT_DIR, \"TB\")\nRESIZE_TO = (256, 256)\n\nos.makedirs(NORMAL_DIR, exist_ok=True)\nos.makedirs(TB_DIR, exist_ok=True)\n\nrecords = []  # filename, label, source\n\n\ndef save_image(src_path, label, source_name, counter, is_dicom=False):\n    \"\"\"Convert (if DICOM) / copy + resize an image, save with a unique\n    name, and log a metadata record.\"\"\"\n    dest_dir = TB_DIR if label == \"TB\" else NORMAL_DIR\n    new_name = f\"{source_name}_{counter:05d}.png\"\n    dest_path = os.path.join(dest_dir, new_name)\n\n    if is_dicom:\n        ds = pydicom.dcmread(src_path)\n        img = ds.pixel_array.astype(float)\n        slope = float(getattr(ds, \"RescaleSlope\", 1))\n        intercept = float(getattr(ds, \"RescaleIntercept\", 0))\n        img = img * slope + intercept\n        img_min, img_max = img.min(), img.max()\n        if img_max > img_min:\n            img = (img - img_min) / (img_max - img_min) * 255.0\n        img = img.astype(np.uint8)\n        if getattr(ds, \"PhotometricInterpretation\", \"MONOCHROME2\") == \"MONOCHROME1\":\n            img = 255 - img\n        pil_img = Image.fromarray(img)\n    else:\n        pil_img = Image.open(src_path).convert(\"L\")  # force grayscale\n\n    pil_img = pil_img.resize(RESIZE_TO)\n    pil_img.save(dest_path)\n    records.append({\"filename\": new_name, \"label\": label, \"source\": source_name})\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T03:47:03.388548Z","iopub.execute_input":"2026-06-18T03:47:03.389759Z","iopub.status.idle":"2026-06-18T03:47:03.405182Z","shell.execute_reply.started":"2026-06-18T03:47:03.38972Z","shell.execute_reply":"2026-06-18T03:47:03.404085Z"}},"outputs":[],"execution_count":44},{"cell_type":"code","source":"# ---------------------------------------------------------------------\n# SOURCE 1: Saira Kiran / Ishrat Jabeen (Mendeley TB dataset)\n# Folder-based: Normal/ and Tuberculosis/\n# ---------------------------------------------------------------------\nSRC1_DIR =\"/kaggle/input/datasets/fadhillahrandyw/dataset-of-tuberculosis-chest-x-rays-images/Dataset of Tuberculosis Chest X-rays Images\"\n\ncounter = 0\nnormal_folder = os.path.join(SRC1_DIR,\"Normal Chest X-rays\")\nif os.path.isdir(normal_folder):\n    for fname in os.listdir(normal_folder):\n        if fname.lower().endswith((\".png\", \".jpg\", \".jpeg\")):\n            save_image(os.path.join(normal_folder, fnam