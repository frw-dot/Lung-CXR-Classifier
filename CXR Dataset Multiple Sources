gomerySet\", \"CXR_png\"),             # Montgomery\n]\n\ncounter_normal3, counter_tb3 = 0, 0\nfor folder in nlm_folders:\n    if not os.path.isdir(folder):\n        print(f\"WARNING: NLM folder not found: {folder}\")\n        continue\n    for fname in os.listdir(folder):\n        if not fname.lower().endswith(\".png\"):\n            continue\n        label_char = fname[-5]  # the \"X\" in ..._X.png\n        if label_char == \"0\":\n            save_image(os.path.join(folder, fname), \"Normal\", \"nlm\", counter_normal3)\n            counter_normal3 += 1\n        elif label_char == \"1\":\n            save_image(os.path.join(folder, fname), \"TB\", \"nlm\", counter_tb3)\n            counter_tb3 += 1\n\n# ---------------------------------------------------------------------\n# SOURCE 4: DA/DB Delhi dataset (vbookshelf/da-and-db-tb-chest-x-ray-datasets)\n# Folder layout not confirmed yet - inspect first, then fill in the loop\n# below. DA is jpg, DB is dicom (set is_dicom=True only for DB files).\n# ---------------------------------------------------------------------\nSRC4_DIR = \"/kaggle/input/datasets/vbookshelf/da-and-db-tb-chest-x-ray-datasets\"\nimages_dir4 = os.path.join(SRC4_DIR, \"images\")\n \n \ndef label_from_da_db_filename(fname):\n    \"\"\"Filenames look like da_test_nx9.jpg, db_train_p6.dcm,\n    db_test_nd548.dcm etc. The 3rd underscore-separated chunk starts\n    with 'n' (negative/Normal) or 'p' (positive/TB).\"\"\"\n    name_no_ext = os.path.splitext(fname)[0]\n    parts = name_no_ext.split(\"_\")\n    if len(parts) < 3:\n        return None\n    first_char = parts[2][0].lower()\n    if first_char == \"n\":\n        return \"Normal\"\n    elif first_char == \"p\":\n        return \"TB\"\n    return None\n \n \ncounter_normal4, counter_tb4 = 0, 0\nfor sub, is_dicom_flag in [(\"da\", False), (\"db\", True)]:\n    sub_dir = os.path.join(images_dir4, sub)\n    if not os.path.isdir(sub_dir):\n        print(f\"WARNING: folder not found: {sub_dir}\")\n        continue\n    for fname in os.listdir(sub_dir):\n        label = label_from_da_db_filename(fname)\n        if label is None:\n            print(f\"  Skipping unrecognized filename: {fname}\")\n            continue\n        src_path = os.path.join(sub_dir, fname)\n        if label == \"Normal\":\n            save_image(src_path, \"Normal\", \"dadb\", counter_normal4, is_dicom=is_dicom_flag)\n            counter_normal4 += 1\n        else:\n            save_image(src_path, \"TB\", \"dadb\", counter_tb4, is_dicom=is_dicom_flag)\n            counter_tb4 += 1\n","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-06-18T03:47:03.407276Z","iopub.execute_input":"2026-06-18T03:47:03.407623Z","iopub.status.idle":"2026-06-18T03:50:14.280396Z","shell.execute_reply.started":"2026-06-18T03:47:03.407579Z","shell.execute_reply":"2026-06-18T03:50:14.279495Z"}},"outputs":[{"name":"stdout","text":"Label counts:\nlabel\nTB        3317\nNormal    1073\nName: count, dtype: int64\n\nSource counts:\nsource\nsairakiran    3008\nnlm            800\nbelarus        304\ndadb           278\nName: count, dtype: int64\nsource      label \nbelarus     TB         304\ndadb        Normal     153\n            TB         125\nnlm         Normal     406\n            TB         394\nsairakiran  Normal     514\n            TB        2494\ndtype: int64\n['datasets']\n","output_type":"stream"}],"execution_count":45},{"cell_type":"code","source":"# ---------------------------------------------------------------------\n# Save combined metadata\n# ---------------------------------------------------------------------\ndf = pd.DataFrame(records)\ndf.to_csv(os.path.join(OUTPUT_DIR, \"combined_metadata.csv\"), index=False)\n\nprint(\"Label counts:\")\nprint(df[\"label\"].value_counts())\nprint(\"\\nSource counts:\")\nprint(df[\"source\"].value_counts())\nprint(df.groupby([\"source\",\"label\"